{
  "name": "cekio-contracts",
  "version": "0.1.0",
  "description": "On-chain post-dated cheque (çek) smart contracts with yield-bearing escrow",
  "license": "MIT",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node",
    "e2e": "hardhat run scripts/e2e-local.ts",
    "deploy:local": "hardhat run scripts/deploy-testnet.ts --network localhost",
    "automation:local": "hardhat run scripts/automation-demo.ts --network localhost",
    "deploy:testnet": "hardhat run scripts/deploy-testnet.ts --network baseSepolia",
    "deploy:sepolia": "hardhat run scripts/deploy-testnet.ts --network sepolia",
    "demo:sepolia": "hardhat run scripts/demo.ts --network sepolia",
    "verify:sepolia": "hardhat verify --network sepolia",
    "demo:testnet": "hardhat run scripts/demo.ts --network baseSepolia",
    "verify:testnet": "hardhat verify --network baseSepolia"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^16.6.1",
    "hardhat": "^2.22.10",
    "solc": "^0.8.24",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0"
  }
}
